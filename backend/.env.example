# Copy to .env and set values. Dev: terminal 1 - cd backend && npm install && npm run dev
# Terminal 2 - cd frontend && npm install && npm run dev (see frontend/.env.example)

# production | development (optional; enables stricter logging and security headers when production)
# NODE_ENV=production

# --- SaaS / sessions (required in production) ---
# Generate a long random string (32+ characters). Used to sign the session cookie.
# SESSION_SECRET=

# Public URL of this API (used for Google OAuth callback default). No trailing slash.
# PUBLIC_API_URL=http://localhost:3000

# Where the browser SPA lives (OAuth redirect after Google). No trailing slash.
# FRONTEND_URL=http://localhost:5173

# HTTPS-only session cookies in production (set true behind TLS). Defaults true when NODE_ENV=production.
# COOKIE_SECURE=true

# CORS: with cookie-based auth, set explicit origins in production (comma-separated).
# For local dev with the Vite dev server calling the API on another port, include:
# CORS_ORIGIN=http://localhost:5173
# Leave unset or use * only for permissive dev (less ideal with credentials).

# Max JSON body size (optional)
# JSON_LIMIT=2mb

# --- Access control (optional) ---
# When true, only emails that already exist in the users table can sign in.
# This disables new registrations for both Email OTP and Google OAuth.
# REGISTRATION_CLOSED=true

# DeepL API key (https://www.deepl.com/pro-api)
DEEPL_AUTH_KEY=

# Optional: Pro uses https://api.deepl.com - default is free tier
# DEEPL_API_URL=https://api-free.deepl.com

# --- Text-to-Speech fallback (optional) ---
# Azure AI Speech resource key + region.
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=eastus

# --- OCR (Azure Document Intelligence) ---
# Used to extract text + word polygons from PDF pages for highlight/copy/TTS.
# AZURE_DOCINTEL_ENDPOINT=https://<resource>.cognitiveservices.azure.com
# AZURE_DOCINTEL_KEY=

# Optional (default 3000). If you see EADDRINUSE, pick another port here and point the frontend at the same host/port (or Vite proxy target).
# PORT=3001

# PostgreSQL - use either DATABASE_URL or the fields below (as in your .env)
# DATABASE_URL=postgres://user:password@localhost:5432/duenote
#
# DATABASE_HOSTNAME=localhost
# DATABASE_DATABASE=duenote
# DATABASE_USERNAME=duenote_user
# DATABASE_PASSWORD=
# DATABASE_PORT=5432

# --- Google OAuth (optional; leave empty to disable “Continue with Google”) ---
# Create OAuth 2.0 credentials in Google Cloud Console; authorized redirect URI must match
# GOOGLE_CALLBACK_URL exactly (defaults to {PUBLIC_API_URL}/auth/google/callback).
# Also supported: /api/auth/google/callback - mount exposes both /auth/* and /api/auth/*.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# --- Email OTP (SMTP) - required in production for email sign-in; optional in dev (code is logged to console) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="DueNote" <noreply@example.com>

# --- File uploads (avatars + course materials) ---
# Local directories used when S3 is not configured (bucket or region empty).
# AVATAR_UPLOAD_DIR=./data/uploads/avatars
# MATERIALS_UPLOAD_DIR=./data/uploads/materials
# Max upload size in bytes (default 2 MiB avatars / 100 MiB materials, each capped in code)
# AVATAR_MAX_BYTES=2097152
# MATERIALS_MAX_BYTES=104857600

# S3: set bucket + region to store all new uploads in S3 (avatars and course PDFs/docs).
# Leave S3_BUCKET or S3_REGION unset (or empty) to keep using local dirs above.
# On EC2/ECS/Lambda, omit AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY and use an instance/task role.
# S3_REGION can be omitted if AWS_REGION is already set in the environment.
# S3_BUCKET=
# S3_REGION=
# S3_KEY_PREFIX=
# S3_PUBLIC_BASE_URL=https://d111111abcdef8.cloudfront.net
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
